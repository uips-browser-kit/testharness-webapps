{
	admin off
}

# Platform management
http://harness.local {
	request_header -X-Harness-App
	request_header -X-Harness-Env
	reverse_proxy harness:8000
}

# Identity provider
http://idp.local {
	reverse_proxy idp:8080
}

# Prometheus UI
http://metrics.local {
	reverse_proxy metrics:9090
}

# Salesforce — dev
http://salesforce-dev.local {
	request_header -X-Harness-App
	request_header -X-Harness-Env
	request_header X-Harness-App "salesforce"
	request_header X-Harness-Env "dev"
	reverse_proxy harness:8000
}

# Salesforce — prod
